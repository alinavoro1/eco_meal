{% extends 'base.html.twig' %}

{% block title %}My Profile – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header" style="margin-bottom: 28px;">
        <div style="display: flex; flex-direction: column; gap: 4px;">
            <div style="display: flex; align-items: center; gap: 8px; color: var(--primary); font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
                <i class="bi bi-person-badge"></i> Account Management
            </div>
            <h1 style="margin: 0;">My Profile</h1>
        </div>
        <a href="{{ path('app_home') }}" class="eco-btn eco-btn-ghost" style="display: inline-flex; align-items: center; gap: 6px;">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    <div style="max-width: 640px; margin: 0 auto;">
        {% if not isEdit %}
            <!-- View Mode Card -->
            <div class="eco-detail-card" style="padding: 32px; position: relative;">
                <div style="position: absolute; top: 24px; right: 24px;">
                    <a href="{{ path('app_profile', {edit: 1}) }}" class="eco-btn eco-btn-primary" style="display: inline-flex; align-items: center; gap: 6px; background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%); border: none; box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);">
                        <i class="bi bi-pencil-square"></i> Edit Credentials
                    </a>
                </div>

                <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 28px;">
                    <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--primary-soft); display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.5rem; font-weight: 700;">
                        {{ user.email|slice(0, 1)|upper }}
                    </div>
                    <div>
                        <h2 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text);">Account Credentials</h2>
                        <span class="badge" style="background: var(--border); color: var(--text-muted); font-size: 11px; margin-top: 4px; display: inline-block;">
                            {% if 'ROLE_ADMIN' in user.roles %}
                                🛡️ System Administrator
                            {% elseif 'ROLE_BUSINESS' in user.roles %}
                                🏢 Business Owner
                            {% else %}
                                👤 Consumer Account
                            {% endif %}
                        </span>
                    </div>
                </div>

                <div class="eco-detail-row" style="padding: 16px 0; border-bottom: 1px solid var(--border);">
                    <span class="eco-detail-label" style="font-weight: 600; color: var(--text-muted);">Email Address</span>
                    <span class="eco-detail-value" style="font-weight: 700; color: var(--text);">{{ user.email }}</span>
                </div>

                <div class="eco-detail-row" style="padding: 16px 0; border-bottom: 1px solid var(--border);">
                    <span class="eco-detail-label" style="font-weight: 600; color: var(--text-muted);">Password</span>
                    <span class="eco-detail-value" style="color: var(--text-muted); font-family: monospace;">••••••••</span>
                </div>

                <!-- Extra Role details -->
                {% if user.consumer %}
                    <div style="margin-top: 28px; padding-top: 24px; border-top: 2px dashed var(--border);">
                        <h3 style="font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
                            <i class="bi bi-person-fill" style="color: var(--primary);"></i> Consumer Profile
                        </h3>
                        <div class="eco-detail-row" style="padding: 12px 0;">
                            <span class="eco-detail-label" style="color: var(--text-muted);">Name</span>
                            <span class="eco-detail-value" style="font-weight: 600;">{{ user.consumer.name }}</span>
                        </div>
                        <div class="eco-detail-row" style="padding: 12px 0;">
                            <span class="eco-detail-label" style="color: var(--text-muted);">Preferred Categories</span>
                            <span class="eco-detail-value">
                                {% if user.consumer.preferredCategories|length > 0 %}
                                    <div style="display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end;">
                                        {% for cat in user.consumer.preferredCategories %}
                                            <span class="badge badge-amber">{{ cat.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <span style="color: var(--text-muted); font-style: italic;">None set</span>
                                {% endif %}
                            </span>
                        </div>
                    </div>
                {% elseif user.business %}
                    <div style="margin-top: 28px; padding-top: 24px; border-top: 2px dashed var(--border);">
                        <h3 style="font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
                            <i class="bi bi-building" style="color: var(--primary);"></i> Business Profile
                        </h3>
                        <div class="eco-detail-row" style="padding: 12px 0;">
                            <span class="eco-detail-label" style="color: var(--text-muted);">Company Name</span>
                            <span class="eco-detail-value" style="font-weight: 600;">{{ user.business.name }}</span>
                        </div>
                        <div class="eco-detail-row" style="padding: 12px 0;">
                            <span class="eco-detail-label" style="color: var(--text-muted);">City</span>
                            <span class="eco-detail-value" style="font-weight: 600;">{{ user.business.city }}</span>
                        </div>
                        <div class="eco-detail-row" style="padding: 12px 0;">
                            <span class="eco-detail-label" style="color: var(--text-muted);">Description</span>
                            <span class="eco-detail-value" style="max-width: 300px; text-align: right;">{{ user.business.description }}</span>
                        </div>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <!-- Edit Mode Form Card -->
            <div class="eco-form-card" style="padding: 32px;">
                <h2 class="eco-form-title" style="margin-bottom: 8px;">Edit Account Credentials</h2>
                <p style="color: var(--text-muted); font-size: 13px; margin-bottom: 24px;">
                    Update your email address or password. For security, you must enter your current password to authorize these changes.
                </p>

                {{ form_start(form) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.plainPassword) }}
                    
                    <div style="background: #f8fafc; border: 1px solid var(--border); border-radius: 12px; padding: 16px; margin: 24px 0;">
                        {{ form_row(form.currentPassword) }}
                    </div>

                    <div style="display: flex; gap: 12px; margin-top: 28px;">
                        {{ form_widget(form.submit, {
                            attr: { class: 'eco-btn eco-btn-primary', style: 'flex: 1; margin: 0; border: none; cursor: pointer;' }
                        }) }}
                        <a href="{{ path('app_profile') }}" class="eco-btn eco-btn-cancel" style="flex: 1; text-align: center; display: inline-flex; justify-content: center; align-items: center; margin: 0;">Cancel</a>
                    </div>
                {{ form_end(form) }}
            </div>
        {% endif %}
    </div>
{% endblock %}
