{% extends 'base.html.twig' %}

{% block title %}Sign In – Eco Meal{% endblock %}

{% block body %}
    <div style="display: flex; align-items: center; justify-content: center; min-height: 60vh;">
        <div class="eco-form-card" style="max-width: 450px; width: 100%;">
            <h1 style="font-size: 1.8rem; margin: 0 0 8px 0; text-align: center; color: var(--primary);">Welcome back</h1>
            <p style="text-align: center; color: var(--text-muted); margin: 0 0 28px 0;">Sign in to your account</p>

            {% if error %}
                <div style="background: #fee; border: 1px solid #fca; border-radius: var(--radius-sm); padding: 12px 14px; margin-bottom: 20px; color: var(--danger); font-size: 14px;">
                    ⚠️ {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div style="background: var(--primary-soft); border: 1px solid var(--primary); border-radius: var(--radius-sm); padding: 12px 14px; margin-bottom: 20px; color: var(--primary-dark); font-size: 14px;">
                    ✓ Logged in as {{ app.user.userIdentifier }} <a href="{{ logout_path() }}" style="color: var(--primary-dark); font-weight: 600; margin-left: 8px;">Logout</a>
                </div>
            {% endif %}

            <form method="post">
                <div style="margin-bottom: 18px;">
                    <label for="username" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--text); font-size: 14px;">Email Address</label>
                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="username"
                           class="eco-input"
                           autocomplete="email"
                           required
                           autofocus
                           placeholder="your@email.com"
                           style="width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 14px; font-family: inherit; transition: border-color var(--transition);"
                    >
                </div>

                <div style="margin-bottom: 24px;">
                    <label for="password" style="display: block; font-weight: 600; margin-bottom: 6px; color: var(--text); font-size: 14px;">Password</label>
                    <input type="password"
                           name="_password"
                           id="password"
                           class="eco-input"
                           autocomplete="current-password"
                           required
                           placeholder="••••••••"
                           style="width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: var(--radius-sm); font-size: 14px; font-family: inherit; transition: border-color var(--transition);"
                    >
                </div>

                <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="eco-btn eco-btn-primary" style="width: 100%; justify-content: center; font-size: 15px; padding: 12px 20px;">
                    Sign In
                </button>
            </form>

            <div style="margin-top: 20px; text-align: center; padding-top: 20px; border-top: 1px solid var(--border);">
                <p style="margin: 0; color: var(--text-muted); font-size: 14px;">
                    Don't have an account?
                    <a href="{{ path('app_register') }}" style="color: var(--primary); font-weight: 600;">Register here</a>
                </p>
            </div>
        </div>
    </div>

    <style>
        .eco-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(16,185,129,0.08);
        }
    </style>
{% endblock %}
