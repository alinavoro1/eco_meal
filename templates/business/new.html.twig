{% extends 'base.html.twig' %}

{% block title %}New Business – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>New Business</h1>
        <a href="{{ path('app_business') }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-form-card" style="max-width: 580px;">
        <p class="eco-form-title">Business Details</p>
        {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.city) }}
        {{ form_row(form.street) }}
        {{ form_row(form.houseNumber) }}
        {{ form_row(form.phoneNumber) }}
        {{ form_row(form.businessType) }}

        {% if form.email is defined %}
            <hr class="my-4" style="border-top: 1px solid var(--border); margin: 24px 0;">
            <p class="eco-form-title">Account Credentials</p>
            {{ form_row(form.email) }}
            {{ form_row(form.password) }}
        {% endif %}

        <div style="display: flex; gap: 10px; margin-top: 28px;">
            {{ form_widget(form.submit, {
                attr: { class: 'eco-btn eco-btn-primary', style: 'flex: 1; margin: 0; border: none; cursor: pointer;' },
                label: 'Create Business'
            }) }}
            <a href="{{ path('app_business') }}" class="eco-btn eco-btn-cancel" style="flex: 1; text-align: center; display: inline-flex; justify-content: center; align-items: center;">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
