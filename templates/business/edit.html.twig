{% extends 'base.html.twig' %}

{% block title %}Edit Business – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Edit Business</h1>
        <a href="{{ path('app_business_view', {id: form.vars.data.id}) }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-form-card">
        <p class="eco-form-title">{{ form.vars.data.name }}</p>
        {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.city) }}
        {{ form_row(form.street) }}
        {{ form_row(form.houseNumber) }}
        {{ form_row(form.phoneNumber) }}
        {{ form_row(form.businessType) }}

        <div style="display: flex; gap: 10px; margin-top: 24px;">
            {{ form_widget(form.submit, {
                attr: { class: 'eco-btn eco-btn-primary', style: 'flex: 1; margin: 0; border: none; cursor: pointer;' },
                label: 'Save Changes'
            }) }}
            <a href="{{ path('app_business_view', {id: form.vars.data.id}) }}" class="eco-btn eco-btn-cancel" style="flex: 1; text-align: center; display: inline-flex; justify-content: center; align-items: center;">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
