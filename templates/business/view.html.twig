{% extends 'base.html.twig' %}

{% block title %}{{ business.name }} – Eco Meal{% endblock %}

{% block body %}

    <div class="eco-page-header">
        <h1>{{ business.name }}</h1>
    </div>

    <div class="eco-detail-card">
        <div class="eco-detail-row">
            <span class="eco-detail-label">ID</span>
            <span class="eco-detail-value">{{ business.id }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Name</span>
            <span class="eco-detail-value">{{ business.name }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">City</span>
            <span class="eco-detail-value">{{ business.city }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Street</span>
            <span class="eco-detail-value">{{ business.street }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">House No.</span>
            <span class="eco-detail-value">{{ business.houseNumber }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Phone</span>
            <span class="eco-detail-value">{{ business.phoneNumber }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Business Type</span>
            <span class="eco-detail-value"><span class="badge badge-violet">{{ business.businessType.name }}</span></span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Account</span>
            <span class="eco-detail-value">
                {% if business.user %}
                    <span class="badge badge-green">✓ {{ business.user.email }}</span>
                {% else %}
                    <span class="badge badge-amber">⚠ No account yet</span>
                {% endif %}
            </span>
        </div>

        <div class="eco-detail-actions">
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_business_add_package', {id: business.id}) }}" class="eco-btn eco-btn-primary">+ Add Package</a>
                <a href="{{ path('app_business_edit', {id: business.id}) }}" class="eco-btn eco-btn-ghost">Edit</a>
                {% if not business.user %}
                    <a href="{{ path('app_business_create_account', {id: business.id}) }}" class="eco-btn eco-btn-secondary">🔑 Create Account</a>
                {% endif %}
                <a href="{{ path('app_business') }}" class="eco-btn eco-btn-ghost">← Back</a>
                <a href="{{ path('app_business_delete', {id: business.id}) }}" class="eco-btn eco-btn-danger"
                   onclick="return confirm('Delete this business?')">Delete</a>
            {% else %}
                <a href="{{ path('app_business_add_package', {id: business.id}) }}" class="eco-btn eco-btn-primary">+ Add Package</a>
                <a href="{{ path('app_business_edit', {id: business.id}) }}" class="eco-btn eco-btn-ghost">Edit</a>
            {% endif %}
        </div>

    </div>

    <div style="margin-top: 40px;">
        <h2 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 20px; color: var(--text);">Packages</h2>

        {% if business.packages|length > 0 %}
            <div class="eco-packages-grid">
                {% for package in business.packages %}
                    <div class="eco-package-card">
                        {% if package.photo %}
                            <div class="eco-package-image">
                                <img src="{{ package.photo }}" alt="{{ package.name }}" />
                            </div>
                        {% else %}
                            <div class="eco-package-image-empty">
                                <span style="font-size: 2.5rem;">📦</span>
                            </div>
                        {% endif %}

                        <div class="eco-package-content">
                            <h3 class="eco-package-name">{{ package.name }}</h3>
                            <p class="eco-package-description">{{ package.description }}</p>

                            <div class="eco-package-meta">
                                <span class="eco-package-price">{{ package.price }} lei</span>
                                <span class="badge badge-amber">{{ package.category.name }}</span>
                            </div>

                            <div class="eco-package-actions">
                                <a href="{{ path('app_package_view', {id: package.id}) }}" class="eco-btn eco-btn-primary" style="flex: 1; text-align: center;">View</a>
                                <a href="{{ path('app_package_edit', {id: package.id}) }}" class="eco-btn eco-btn-ghost">Edit</a>
                                <a href="{{ path('app_package_delete', {id: package.id}) }}" class="eco-btn eco-btn-danger" onclick="return confirm('Delete this package?')">Delete</a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="eco-empty" style="background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);">
                📦 No packages yet. <a href="{{ path('app_business_add_package', {id: business.id}) }}" style="color: var(--primary); font-weight: 600;">Create one</a>
            </div>
        {% endif %}
    </div>

{% endblock %}
