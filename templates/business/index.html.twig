{% extends 'base.html.twig' %}

{% block title %}Businesses – Eco Meal{% endblock %}

{% block body %}

    <div class="eco-page-header">
        <h1>Businesses</h1>
        <div style="display: flex; gap: 10px;">
            <button type="button" class="eco-btn" style="background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%); color: #fff; border: none; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);" data-bs-toggle="modal" data-bs-target="#filterModal">
                <i class="bi bi-sliders"></i> Filter
            </button>
            <a href="{{ path('app_business_new') }}" class="eco-btn eco-btn-primary">+ New Business</a>
        </div>
    </div>

    <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
                <div class="modal-header" style="border-bottom: 1px solid var(--border); padding: 20px 24px;">
                    <h5 class="modal-title" id="filterModalLabel" style="font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-sliders" style="color: #8b5cf6;"></i> Filter Businesses
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(business_filter_form) }}
                <div class="modal-body" style="padding: 24px;">
                    <div class="mb-3">
                        {{ form_row(business_filter_form.name) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(business_filter_form.city) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(business_filter_form.businessType) }}
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid var(--border); padding: 16px 24px; display: flex; gap: 10px;">
                    <a href="{{ path('app_business') }}" class="eco-btn eco-btn-cancel" style="margin: 0; flex: 1; text-align: center; display: inline-flex; align-items: center; justify-content: center;">
                        Reset Filters
                    </a>
                    {{ form_widget(business_filter_form.submit, {
                        attr: { class: 'eco-btn eco-btn-primary', style: 'margin: 0; flex: 1; background: #8b5cf6; border: none; cursor: pointer;' },
                        label: 'Apply Filters'
                    }) }}
                </div>
                {{ form_end(business_filter_form) }}
            </div>
        </div>
    </div>

    <div class="eco-table-wrap">
        <div style="overflow-x:auto;">
            <table class="eco-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>City</th>
                    <th>Street</th>
                    <th>No.</th>
                    <th>Phone</th>
                    <th>Type</th>
                </tr>
                </thead>
                <tbody>
                {% for business in businesses %}
                    <tr>
                        <td class="id-cell">{{ business.id }}</td>
                        <td>
                            <a href="{{ path('app_business_view', {id: business.id}) }}" class="table-link">
                                {{ business.name }}
                            </a>
                        </td>
                        <td>{{ business.city }}</td>
                        <td>{{ business.street }}</td>
                        <td>{{ business.houseNumber }}</td>
                        <td>{{ business.phoneNumber }}</td>
                        <td><span class="badge badge-violet">{{ business.businessType.name }}</span></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="eco-empty">No businesses found.</div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}
