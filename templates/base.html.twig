<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Eco Meal – Eco-friendly food delivery platform">
    <title>{% block title %}Eco Meal{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
{#    //used bootstrap icons!!#}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {{ importmap('app') }}

    <style>
        .eco-navbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }
        .eco-navbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            height: 62px;
            gap: 12px;
        }
        .eco-brand {
            font-size: 1.25rem;
            font-weight: 800;
            color: #10b981;
            text-decoration: none;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
        }
        .eco-brand i {
            font-size: 1.4rem;
            color: #10b981;
        }
        .eco-brand .brand-dot {
            width: 8px;
            height: 8px;
            background: #8b5cf6;
            border-radius: 50%;
            display: inline-block;
            margin-bottom: 1px;
        }
        .eco-brand:hover {
            color: #059669;
            text-decoration: none;
        }
        .eco-nav {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .eco-nav a {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 8px;
            font-size: 13.5px;
            font-weight: 500;
            color: #475569;
            text-decoration: none;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
        }
        .eco-nav a .nav-icon {
            font-size: 1rem;
            line-height: 1;
            display: inline-flex;
            align-items: center;
        }
        .eco-nav a:hover { background: #ecfdf5; color: #059669; text-decoration: none; }
        .eco-nav .nav-logout a { color: #ef4444; }
        .eco-nav .nav-logout a:hover { background: #fff0f0; color: #dc2626; }
        @media (max-width: 768px) {
            .eco-nav { display: none !important; }
        }
    </style>
</head>

<body>

<header class="eco-navbar">
    <div class="eco-navbar-inner">
        <a href="{% if app.user %}{% if is_granted('ROLE_ADMIN') %}{{ path('app_home') }}{% elseif is_granted('ROLE_BUSINESS') and app.user.getBusiness() %}{{ path('app_business_view', {id: app.user.getBusiness().getId()}) }}{% else %}{{ path('app_package') }}{% endif %}{% else %}{{ path('app_login') }}{% endif %}" class="eco-brand">
            🌿 EcoMeal <span class="brand-dot"></span>
        </a>

        {% if app.user %}
            <a href="{{ path('app_logout') }}" class="mobile-logout-btn" onclick="return confirm('Are you sure you want to log out?');" title="Logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        {% endif %}

        <nav>
            <ul class="eco-nav" id="eco-nav">
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li><a href="{{ path('app_home') }}"><i class="bi bi-house nav-icon"></i> Home</a></li>
                        <li><a href="{{ path('app_business') }}"><i class="bi bi-building nav-icon"></i> Businesses</a></li>
                        <li><a href="{{ path('app_business_type') }}"><i class="bi bi-tags nav-icon"></i> Types</a></li>
                        <li><a href="{{ path('app_consumer') }}"><i class="bi bi-people nav-icon"></i> Consumers</a></li>
                        <li><a href="{{ path('app_category') }}"><i class="bi bi-grid-3x3-gap nav-icon"></i> Categories</a></li>
                        <li><a href="{{ path('app_package') }}"><i class="bi bi-box-seam nav-icon"></i> Packages</a></li>
                        <li><a href="{{ path('app_order') }}"><i class="bi bi-receipt nav-icon"></i> Orders</a></li>
                        <li><a href="{{ path('app_profile') }}"><i class="bi bi-person-circle nav-icon"></i> My Account</a></li>
                    {% elseif is_granted('ROLE_BUSINESS') and app.user.getBusiness() %}
                        <li><a href="{{ path('app_business_view', {id: app.user.getBusiness().getId()}) }}"><i class="bi bi-house nav-icon"></i> Home</a></li>
                        <li><a href="{{ path('app_package') }}"><i class="bi bi-box-seam nav-icon"></i> Packages</a></li>
                        <li><a href="{{ path('app_order') }}"><i class="bi bi-receipt nav-icon"></i> Orders</a></li>
                        <li><a href="{{ path('app_business_view', {id: app.user.getBusiness().getId()}) }}"><i class="bi bi-person-circle nav-icon"></i> My Account</a></li>
                    {% elseif is_granted('ROLE_CONSUMER') or app.user.getConsumer() %}
                        <li><a href="{{ path('app_package') }}"><i class="bi bi-house nav-icon"></i> Home</a></li>
                        <li><a href="{{ path('app_order') }}"><i class="bi bi-receipt nav-icon"></i> My Orders</a></li>
                        {% if app.user.getConsumer() %}
                            <li><a href="{{ path('app_consumer_view', {id: app.user.getConsumer().getId()}) }}"><i class="bi bi-person-circle nav-icon"></i> My Account</a></li>
                        {% endif %}
                    {% endif %}
                    <li class="nav-logout"><a href="{{ path('app_logout') }}" onclick="return confirm('Sigur doriți să vă deconectați?');"><i class="bi bi-box-arrow-right nav-icon"></i> Logout</a></li>
                {% else %}
                    <li><a href="{{ path('app_login') }}"><i class="bi bi-key nav-icon"></i> Login</a></li>
                    <li><a href="{{ path('app_register') }}"><i class="bi bi-person-plus nav-icon"></i> Register</a></li>
                {% endif %}
            </ul>
        </nav>
    </div>
</header>

<main class="eco-main">
    <div class="container">
        {% block body %}{% endblock %}
    </div>
</main>

{% if app.user %}
<nav class="eco-bottom-nav">
    <div class="eco-bottom-nav-inner">
        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_business') }}"><div class="icon-bubble"><i class="bi bi-building"></i></div><span class="nav-text">Businesses</span></a>
            <a href="{{ path('app_package') }}"><div class="icon-bubble"><i class="bi bi-box-seam"></i></div><span class="nav-text">Packages</span></a>
            <a href="{{ path('app_home') }}" class="nav-home-center"><div class="icon-bubble"><i class="bi bi-house"></i></div><span class="nav-text">Home</span></a>
            <a href="{{ path('app_order') }}"><div class="icon-bubble"><i class="bi bi-receipt"></i></div><span class="nav-text">Orders</span></a>
            <a href="{{ path('app_profile') }}"><div class="icon-bubble"><i class="bi bi-person-circle"></i></div><span class="nav-text">Profile</span></a>
        {% elseif is_granted('ROLE_BUSINESS') and app.user.getBusiness() %}
            <a href="{{ path('app_package') }}"><div class="icon-bubble"><i class="bi bi-box-seam"></i></div><span class="nav-text">Packages</span></a>
            <a href="{{ path('app_business_view', {id: app.user.getBusiness().getId()}) }}" class="nav-home-center"><div class="icon-bubble"><i class="bi bi-house"></i></div><span class="nav-text">Home</span></a>
            <a href="{{ path('app_order') }}"><div class="icon-bubble"><i class="bi bi-receipt"></i></div><span class="nav-text">Orders</span></a>
        {% elseif is_granted('ROLE_CONSUMER') or app.user.getConsumer() %}
            <a href="{{ path('app_order') }}"><div class="icon-bubble"><i class="bi bi-receipt"></i></div><span class="nav-text">Orders</span></a>
            <a href="{{ path('app_package') }}" class="nav-home-center"><div class="icon-bubble"><i class="bi bi-house"></i></div><span class="nav-text">Home</span></a>
            {% if app.user.getConsumer() %}
                <a href="{{ path('app_consumer_view', {id: app.user.getConsumer().getId()}) }}"><div class="icon-bubble"><i class="bi bi-person-circle"></i></div><span class="nav-text">Profile</span></a>
            {% else %}
                <a href="{{ path('app_profile') }}"><div class="icon-bubble"><i class="bi bi-person-circle"></i></div><span class="nav-text">Profile</span></a>
            {% endif %}
        {% endif %}
    </div>
</nav>
{% else %}
<nav class="eco-bottom-nav">
    <div class="eco-bottom-nav-inner">
        <a href="{{ path('app_login') }}"><div class="icon-bubble"><i class="bi bi-key"></i></div><span class="nav-text">Login</span></a>
        <a href="{{ path('app_register') }}"><div class="icon-bubble"><i class="bi bi-person-plus"></i></div><span class="nav-text">Register</span></a>
    </div>
</nav>
{% endif %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
