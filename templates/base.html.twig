<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Eco Meal – Admin panel for eco-friendly food delivery">
    <title>{% block title %}Eco Meal{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    {{ importmap('app') }}

    <style>
        .eco-navbar {
            background: #fff;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }
        .eco-navbar-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            height: 62px;
        }
        .eco-brand {
            font-size: 1.25rem;
            font-weight: 800;
            color: #10b981;
            text-decoration: none;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
        }
        .eco-brand .brand-dot {
            width: 8px;
            height: 8px;
            background: #8b5cf6;
            border-radius: 50%;
            display: inline-block;
            margin-bottom: 1px;
        }
        .eco-brand:hover {
            color: #059669;
            text-decoration: none;
        }
        .eco-nav {
            display: flex;
            align-items: center;
            gap: 2px;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .eco-nav a {
            display: block;
            padding: 7px 13px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            color: #475569;
            text-decoration: none;
            transition: background 0.18s, color 0.18s;
            white-space: nowrap;
        }
        .eco-nav a:hover {
            background: #ecfdf5;
            color: #059669;
            text-decoration: none;
        }
        .eco-hamburger {
            display: none;
            background: none;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            color: #64748b;
            cursor: pointer;
            padding: 6px 10px;
            font-size: 19px;
            line-height: 1;
        }
        .eco-hamburger:hover {
            background: #f1f5f9;
        }
        @media (max-width: 900px) {
            .eco-hamburger { display: flex; align-items: center; }
            .eco-nav {
                display: none;
                position: absolute;
                top: 62px;
                left: 0;
                right: 0;
                background: #fff;
                border-bottom: 1px solid #e2e8f0;
                flex-direction: column;
                padding: 10px 16px 16px;
                gap: 2px;
                box-shadow: 0 8px 20px rgba(0,0,0,0.08);
            }
            .eco-nav.open {
                display: flex;
            }
            .eco-nav a {
                width: 100%;
                padding: 11px 14px;
            }
        }
    </style>
</head>

<body>

<header class="eco-navbar">
    <div class="eco-navbar-inner">
        <a href="{{ path('app_home') }}" class="eco-brand">
            🌿 EcoMeal <span class="brand-dot"></span>
        </a>
        <button class="eco-hamburger" onclick="document.getElementById('eco-nav').classList.toggle('open')" aria-label="Menu">
            ☰
        </button>
        <nav>
            <ul class="eco-nav" id="eco-nav">
                <li><a href="{{ path('app_business') }}">Businesses</a></li>
                <li><a href="{{ path('app_business_type') }}">Business Types</a></li>
                <li><a href="{{ path('app_consumer') }}">Consumers</a></li>
                <li><a href="{{ path('app_category') }}">Categories</a></li>
                <li><a href="{{ path('app_package') }}">Packages</a></li>
                <li><a href="{{ path('app_order') }}">Orders</a></li>
            </ul>
        </nav>
    </div>
</header>

<main class="eco-main">
    <div class="container">
        {% block body %}{% endblock %}
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
