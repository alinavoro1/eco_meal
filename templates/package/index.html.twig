{% extends 'base.html.twig' %}

{% block title %}Packages – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>All Packages</h1>
        <a href="{{ path('app_package') }}" class="eco-btn eco-btn-primary">Refresh</a>
    </div>

    <div style="margin-bottom: 24px;">
        <button type="button" class="eco-btn" style="background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%); color: #fff; border: none; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);" data-bs-toggle="modal" data-bs-target="#filterModal">
            <i class="bi bi-sliders"></i> Filter Packages
        </button>
    </div>

    <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
                <div class="modal-header" style="border-bottom: 1px solid var(--border); padding: 20px 24px;">
                    <h5 class="modal-title" id="filterModalLabel" style="font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-sliders" style="color: #8b5cf6;"></i> Filter Packages
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(package_filter_form) }}
                <div class="modal-body" style="padding: 24px;">
                    <div class="mb-3">
                        {{ form_row(package_filter_form.name, { 'label': 'Search (Name or Description)' }) }}
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            {{ form_row(package_filter_form.minPrice) }}
                        </div>
                        <div class="col-6 mb-3">
                            {{ form_row(package_filter_form.maxPrice) }}
                        </div>
                    </div>
                    <div class="mb-3">
                        {{ form_row(package_filter_form.category) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(package_filter_form.city) }}
                    </div>
                    {% if package_filter_form.business is defined %}
                        <div class="mb-3">
                            {{ form_row(package_filter_form.business) }}
                        </div>
                    {% endif %}
                </div>
                <div class="modal-footer" style="border-top: 1px solid var(--border); padding: 16px 24px; display: flex; gap: 10px;">
                    <a href="{{ path('app_package') }}" class="eco-btn eco-btn-cancel" style="margin: 0; flex: 1; text-align: center; display: inline-flex; align-items: center; justify-content: center;">
                        Reset Filters
                    </a>
                    {{ form_widget(package_filter_form.submit, {
                        attr: { class: 'eco-btn eco-btn-primary', style: 'margin: 0; flex: 1; background: #8b5cf6; border: none; cursor: pointer;' },
                        label: 'Apply Filters'
                    }) }}
                </div>
                {{ form_end(package_filter_form) }}
            </div>
        </div>
    </div>

    {% if packages|length > 0 %}
        <div class="eco-packages-grid">
            {% for package in packages %}
                <div class="eco-package-card">
                    {% if package.photo %}
                        <div class="eco-package-image">
                            <img src="{{ package.photo }}" alt="{{ package.name }}" />
                        </div>
                    {% else %}
                        <div class="eco-package-image-empty">
                            <span style="font-size: 2.5rem;">📦</span>
                        </div>
                    {% endif %}

                    <div class="eco-package-content">
                        <h3 class="eco-package-name">{{ package.name }}</h3>
                        <p class="eco-package-description">{{ package.description }}</p>

                        <div class="eco-package-meta">
                            <span class="eco-package-price">{{ package.price }} lei</span>
                            <span class="badge badge-amber">{{ package.category.name }}</span>
                        </div>

                        <div style="font-size: 12px; color: var(--text-muted); margin-top: 8px;">
                            from <strong>{{ package.business.name }}</strong>
                        </div>

                        <div class="eco-package-actions" style="margin-top: 12px;">
                            <a href="{{ path('app_package_view', {id: package.id}) }}" class="eco-btn eco-btn-primary" style="flex: 1; text-align: center;">View</a>
                            {% if is_granted('ROLE_CONSUMER') %}
                                <a href="{{ path('app_order_new', {id: package.id}) }}" class="eco-btn eco-btn-secondary">Order</a>
                            {% endif %}
                            {% if app.user and app.user.getBusiness() and app.user.getBusiness().getId() == package.business.id %}
                                <a href="{{ path('app_package_edit', {id: package.id}) }}" class="eco-btn eco-btn-ghost">Edit</a>
                                <a href="{{ path('app_package_delete', {id: package.id}) }}" class="eco-btn eco-btn-danger" onclick="return confirm('Delete this package?')">Delete</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="eco-empty" style="background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);">
            📦 No packages available.
        </div>
    {% endif %}
{% endblock %}
