{% extends 'base.html.twig' %}

{% block title %}Edit Package – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Edit Package</h1>
    </div>

    <div class="eco-form-card" style="max-width: 600px;">
        <h2 class="eco-form-title">{{ form.vars.data.name }}</h2>

        {{ form_start(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.description) }}
            {{ form_row(form.price) }}
            {{ form_row(form.photo, {
                attr: {
                    placeholder: 'https://example.com/image.jpg'
                }
            }) }}
            {{ form_row(form.category) }}
            {{ form_row(form.createdAt) }}

            <div style="display: flex; gap: 10px; margin-top: 24px;">
                {{ form_row(form.submit, {
                    attr: {
                        class: 'eco-btn eco-btn-primary',
                        style: 'flex: 1; margin: 0; border: none; cursor: pointer;'
                    },
                    label: 'Save Changes'
                }) }}
                <a href="{{ path('app_package_view', {id: form.vars.data.id}) }}" class="eco-btn eco-btn-ghost" style="flex: 1; text-align: center; margin: 0;">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
