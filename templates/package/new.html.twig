{% extends 'base.html.twig' %}

{% block title %}Create Package – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Create Package</h1>
        {% if business %}
            <p style="margin: 0; color: var(--text-muted);">for <strong>{{ business.name }}</strong></p>
        {% endif %}
    </div>

    <div class="eco-form-card" style="max-width: 600px;">
        <h2 class="eco-form-title">Package Details</h2>

        {{ form_start(form) }}
            {{ form_row(form.name) }}
            {{ form_row(form.description) }}
            {{ form_row(form.price) }}
            {{ form_row(form.photo, {
                attr: {
                    placeholder: 'https://example.com/image.jpg'
                }
            }) }}
            {{ form_row(form.category) }}

            <div style="display: flex; gap: 10px; margin-top: 24px;">
                {{ form_widget(form.submit, {
                    attr: {
                        class: 'eco-btn eco-btn-primary',
                        style: 'flex: 1; margin: 0; border: none; cursor: pointer;'
                    },
                    label: 'Create Package'
                }) }}
                <a href="{% if business %}{{ path('app_business_view', {id: business.id}) }}{% else %}{{ path('app_package') }}{% endif %}" class="eco-btn eco-btn-cancel" style="flex: 1; text-align: center; margin: 0; display: inline-flex; justify-content: center; align-items: center;">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
