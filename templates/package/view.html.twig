{% extends 'base.html.twig' %}

{% block title %}Hello PackageController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>
    <div class="example-wrapper">
        <p>{{ package.id }}</p>
        <p>{{ package.name }}</p>
        <p>{{ package.description }}</p>
        <p>{{ package.price }}</p>
        {% if package.photo %}
            <img src="{{ package.photo }}"
                 alt="{{ package.name }}"
                 width="300">
        {% else %}
            <p>No image available.</p>
        {% endif %}
        <p>{{ package.createdAt|date('Y-m-d H:i') }}</p>
        <p>{{ package.category.name }}</p>
        <p>{{ package.business.name }}</p>

        <a href="{{ path('app_package') }}">Back</a>
    </div>
{% endblock %}
