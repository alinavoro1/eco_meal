{% extends 'base.html.twig' %}

{% block title %}{{ consumer.firstName }} {{ consumer.lastName }} – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>{{ consumer.firstName }} {{ consumer.lastName }}</h1>
        <a href="{% if is_granted('ROLE_ADMIN') %}{{ path('app_consumer') }}{% else %}{{ path('app_package') }}{% endif %}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-detail-card">
        <div class="eco-detail-row">
            <span class="eco-detail-label">ID</span>
            <span class="eco-detail-value">{{ consumer.id }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">First Name</span>
            <span class="eco-detail-value">{{ consumer.firstName }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Last Name</span>
            <span class="eco-detail-value">{{ consumer.lastName }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Phone</span>
            <span class="eco-detail-value">{{ consumer.phoneNumber }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Email</span>
            <span class="eco-detail-value">{{ consumer.user ? consumer.user.email : '–' }}</span>
        </div>

        <div class="eco-detail-actions">
            {% if is_granted('ROLE_CONSUMER') %}
                <a href="{{ path('app_consumer_edit', {id: consumer.id}) }}" class="eco-btn eco-btn-primary">Edit</a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_consumer_delete', {id: consumer.id}) }}" class="eco-btn eco-btn-danger"
                   onclick="return confirm('Delete this consumer?')">Delete</a>
            {% endif %}
            {% if is_granted('ROLE_CONSUMER') %}
                <a href="{{ path('app_consumer_delete', {id: consumer.id}) }}" class="eco-btn eco-btn-danger"
                onclick="return confirm('Are you sure you want to delete your account?')">Delete</a>
            {% endif %}

        </div>
    </div>
{% endblock %}
