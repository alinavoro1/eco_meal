{% extends 'base.html.twig' %}

{% block title %}My Preferences – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>My Preferences</h1>
        <a href="{{ path('app_package') }}" class="eco-btn eco-btn-ghost">← Back to Packages</a>
    </div>

    {% for message in app.flashes('success') %}
        <div style="background: var(--primary-soft); color: var(--primary); padding: 12px 16px; border-radius: var(--radius-sm); border: 1px solid rgba(16,185,129,0.2); margin-bottom: 24px; font-weight: 600;">
            {{ message }}
        </div>
    {% endfor %}

    <div class="eco-form-card" style="max-width: 500px;">
        <p class="eco-form-title">Select the food categories you prefer</p>
        <p style="color: var(--text-muted); font-size: 14px; margin-bottom: 24px;">
            Only packages from your selected categories will appear in your feed. If you select none, all categories are shown.
        </p>

        {{ form_start(form) }}
            <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px;">
                {{ form_row(form.preferredCategories) }}
            </div>

            <div style="margin-top: 24px; display: flex; gap: 10px;">
                {{ form_widget(form.submit, { attr: { class: 'eco-btn eco-btn-primary', style: 'border: none; cursor: pointer; flex: 1; justify-content: center;' } }) }}
                <a href="{{ path('app_package') }}" class="eco-btn eco-btn-cancel" style="flex: 1; text-align: center; justify-content: center;">Cancel</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
