{% extends 'base.html.twig' %}

{% block title %}Hello ConsumerController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <a href="{{ path('app_consumer_new') }}">Create new consumer</a>
        <br>
        <table>
            <thead>
            <tr>
                <th>Id</th>
                <th>First name</th>
                <th>Last name</th>
                <th>Phone number</th>
            </tr>
            </thead>

            <tbody>

            {% for consumer in consumers %}
                <tr>
                    <td>
                        <a href="{{ path('app_consumer_view', {
                            id: consumer.id
                        }) }}">
                            {{ consumer.id }}
                        </a>
                    </td>

                    <td>{{ consumer.firstName }}</td>
                    <td>{{ consumer.lastName }}</td>
                    <td>{{ consumer.phoneNumber }}</td>

                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
