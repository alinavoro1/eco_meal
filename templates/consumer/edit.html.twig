{% extends 'base.html.twig' %}

{% block title %}Edit Consumer – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Edit Consumer</h1>
        <a href="{{ path('app_consumer_view', {id: form.vars.data.id}) }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-form-card">
        <p class="eco-form-title">Consumer Details</p>
        {{ form_start(form) }}
        {{ form_row(form.firstName) }}
        {{ form_row(form.lastName) }}
        {{ form_row(form.phoneNumber) }}

        <div style="display: flex; gap: 10px; margin-top: 24px;">
            {{ form_row(form.submit, {
                attr: { class: 'eco-btn eco-btn-primary', style: 'flex: 1; margin: 0; border: none; cursor: pointer;' },
                label: 'Save Changes'
            }) }}
            <a href="{{ path('app_consumer_view', {id: form.vars.data.id}) }}" class="eco-btn eco-btn-ghost" style="flex: 1; text-align: center;">Cancel</a>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
