{% extends 'base.html.twig' %}

{% block title %}New Business Type – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>New Business Type</h1>
        <a href="{{ path('app_business_type') }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-form-card">
        <p class="eco-form-title">Business Type Details</p>
        {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.submit) }}
        {{ form_end(form) }}
        <div class="mt-3">
            <a href="{{ path('app_business_type') }}" class="eco-btn eco-btn-ghost">Cancel</a>
        </div>
    </div>
{% endblock %}
