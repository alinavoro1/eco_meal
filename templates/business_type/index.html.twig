{% extends 'base.html.twig' %}

{% block title %}Business Types – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Business Types</h1>
        <a href="{{ path('app_business_type_new') }}" class="eco-btn eco-btn-primary">+ New Type</a>
    </div>

    <div class="eco-table-wrap">
        <div style="overflow-x:auto;">
            <table class="eco-table">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for businessType in businessTypes %}
                    <tr>
                        <td class="id-cell">{{ businessType.id }}</td>
                        <td>
                            <a href="{{ path('app_business_type_view', {id: businessType.id}) }}" class="table-link">
                                {{ businessType.name }}
                            </a>
                        </td>
                        <td>
                            <div style="display: flex; gap: 6px;">
                                <a href="{{ path('app_business_type_edit', {id: businessType.id}) }}" class="eco-btn eco-btn-ghost" style="padding: 6px 14px; font-size: 13px;">Edit</a>
                                <a href="{{ path('app_business_type_delete', {id: businessType.id}) }}" class="eco-btn eco-btn-danger" style="padding: 6px 14px; font-size: 13px;" onclick="return confirm('Delete this type?')">Delete</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3">
                            <div class="eco-empty">No business types found.</div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
