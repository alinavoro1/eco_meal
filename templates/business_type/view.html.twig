{% extends 'base.html.twig' %}

{% block title %}{{ businessType.name }} – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>{{ businessType.name }}</h1>
        <a href="{{ path('app_business_type') }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-detail-card">
        <div class="eco-detail-row">
            <span class="eco-detail-label">ID</span>
            <span class="eco-detail-value">{{ businessType.id }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Name</span>
            <span class="eco-detail-value"><span class="badge badge-violet">{{ businessType.name }}</span></span>
        </div>

        <div class="eco-detail-actions">
            <a href="{{ path('app_business_type_edit', {id: businessType.id}) }}" class="eco-btn eco-btn-primary">Edit</a>
            <a href="{{ path('app_business_type_delete', {id: businessType.id}) }}" class="eco-btn eco-btn-danger"
               onclick="return confirm('Delete this business type?')">Delete</a>
        </div>
    </div>
{% endblock %}
