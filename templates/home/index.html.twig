{% extends 'base.html.twig' %}

{% block title %}Eco Meal – Dashboard{% endblock %}

{% block body %}

    <div style="text-align: center; margin-bottom: 52px; padding-top: 12px;">
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 72px; height: 72px; background: linear-gradient(135deg, #ecfdf5, #d1fae5); border-radius: 20px; margin-bottom: 20px; font-size: 2rem; box-shadow: 0 4px 20px rgba(16,185,129,0.15);">
            🌿
        </div>
        <h1 style="font-size: 2.4rem; font-weight: 800; color: var(--text); letter-spacing: -0.03em; margin: 0 0 10px;">
            Welcome to <span style="color: var(--primary);">EcoMeal</span>
        </h1>
        <p style="color: var(--text-muted); font-size: 1.05rem; max-width: 460px; margin: 0 auto;">
            Manage your food delivery platform from one place.
        </p>
    </div>

    <div class="row g-3">

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_business') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--primary);">
                <div class="eco-dashboard-icon" style="background: var(--primary-soft); color: var(--primary);">🏢</div>
                <div>
                    <div class="eco-dashboard-label">Businesses</div>
                    <div class="eco-dashboard-sub">Manage all businesses</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_business_type') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--secondary);">
                <div class="eco-dashboard-icon" style="background: var(--secondary-soft); color: var(--secondary);">🏷️</div>
                <div>
                    <div class="eco-dashboard-label">Business Types</div>
                    <div class="eco-dashboard-sub">Categories of business</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_consumer') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--primary);">
                <div class="eco-dashboard-icon" style="background: var(--primary-soft); color: var(--primary);">👥</div>
                <div>
                    <div class="eco-dashboard-label">Consumers</div>
                    <div class="eco-dashboard-sub">View & manage users</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_category') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--secondary);">
                <div class="eco-dashboard-icon" style="background: var(--secondary-soft); color: var(--secondary);">🗂️</div>
                <div>
                    <div class="eco-dashboard-label">Categories</div>
                    <div class="eco-dashboard-sub">Food package categories</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_package') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--amber);">
                <div class="eco-dashboard-icon" style="background: var(--amber-soft); color: #b45309;">📦</div>
                <div>
                    <div class="eco-dashboard-label">Packages</div>
                    <div class="eco-dashboard-sub">Eco food packages</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-xl-4">
            <a href="{{ path('app_order') }}" class="eco-dashboard-tile" style="border-top: 3px solid var(--primary);">
                <div class="eco-dashboard-icon" style="background: var(--primary-soft); color: var(--primary);">📋</div>
                <div>
                    <div class="eco-dashboard-label">Orders</div>
                    <div class="eco-dashboard-sub">All customer orders</div>
                </div>
                <span class="eco-dashboard-arrow">→</span>
            </a>
        </div>

    </div>

    <style>
        .eco-dashboard-tile {
            display: flex;
            align-items: center;
            gap: 16px;
            background: var(--surface);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--border);
            padding: 20px 22px;
            text-decoration: none;
            color: var(--text);
            transition: box-shadow var(--transition), transform var(--transition);
            height: 100%;
        }
        .eco-dashboard-tile:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-3px);
            text-decoration: none;
            color: var(--text);
        }
        .eco-dashboard-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
        }
        .eco-dashboard-label {
            font-weight: 700;
            font-size: 15px;
            color: var(--text);
        }
        .eco-dashboard-sub {
            font-size: 12.5px;
            color: var(--text-muted);
            margin-top: 2px;
        }
        .eco-dashboard-arrow {
            margin-left: auto;
            color: var(--text-muted);
            font-size: 1.1rem;
            flex-shrink: 0;
        }
    </style>

{% endblock %}
