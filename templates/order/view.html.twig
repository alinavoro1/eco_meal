{% extends 'base.html.twig' %}

{% block title %}Order #{{ order.id }} – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>Order #{{ order.id }}</h1>
        <a href="{{ path('app_order') }}" class="eco-btn eco-btn-ghost">← Back to Orders</a>
    </div>

    <div class="eco-detail-card">
        <div class="eco-detail-row">
            <span class="eco-detail-label">Order ID</span>
            <span class="eco-detail-value" style="color: var(--primary); font-weight: 700;">#{{ order.id }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Date</span>
            <span class="eco-detail-value">{{ order.createdAt|date('d M Y, H:i') }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Package</span>
            <span class="eco-detail-value">
                <a href="{{ path('app_package_view', {id: order.package.id}) }}" style="color: var(--primary); font-weight: 600;">{{ order.package.name }}</a>
                <span class="badge badge-amber" style="margin-left: 8px;">{{ order.package.category.name }}</span>
            </span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Price</span>
            <span class="eco-detail-value" style="font-size: 1.15rem; font-weight: 700; color: var(--primary);">{{ order.package.price }} lei</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Business</span>
            <span class="eco-detail-value">{{ order.package.business.name }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Consumer</span>
            <span class="eco-detail-value">{{ order.consumer.firstName }} {{ order.consumer.lastName }}<br>
                <span style="font-size: 13px; color: var(--text-muted);">{{ order.consumer.phoneNumber }}</span>
            </span>
        </div>
        <div class="eco-detail-actions" style="margin-top: 24px; display: flex; gap: 12px;">
            {% if (app.user and app.user.consumer and order.consumer and app.user.consumer.id == order.consumer.id) or (app.user and app.user.business and order.package and order.package.business and app.user.business.id == order.package.business.id) %}
                <a href="{{ path('app_order_delete', {id: order.id}) }}" class="eco-btn eco-btn-danger" onclick="return confirm('Cancel this order?')">Cancel Order</a>
            {% endif %}
        </div>
    </div>
{% endblock %}
