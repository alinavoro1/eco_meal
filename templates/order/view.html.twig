{% extends 'base.html.twig' %}

{% block title %}Hello OrderController!{% endblock %}

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">

        <p>{{ order.id }}</p>
        <p>{{ order.createdAt|date('Y-m-d H:i') }}</p>
        <p>{{ order.package.name }}</p>
        <p>{{ order.consumer.firstName }} {{ order.consumer.lastName }}</p>

        <a href="{{ path('app_order') }}">Back</a>

    </div>
{% endblock %}
