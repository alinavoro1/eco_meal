{% extends 'base.html.twig' %}

{% block title %}Orders – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>{% if is_granted('ROLE_ADMIN') %}All Orders{% elseif is_granted('ROLE_CONSUMER') %}My Orders{% else %}Orders{% endif %}</h1>
        <div style="display: flex; gap: 10px;">
            <button type="button" class="eco-btn" style="background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 100%); color: #fff; border: none; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 4px 12px rgba(139, 92, 246, 0.25);" data-bs-toggle="modal" data-bs-target="#filterModal">
                <i class="bi bi-sliders"></i> Filter
            </button>
            {% if is_granted('ROLE_CONSUMER') %}
                <a href="{{ path('app_order_new') }}" class="eco-btn eco-btn-primary">+ New Order</a>
            {% endif %}
        </div>
    </div>

    <div class="modal fade" id="filterModal" tabindex="-1" aria-labelledby="filterModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
                <div class="modal-header" style="border-bottom: 1px solid var(--border); padding: 20px 24px;">
                    <h5 class="modal-title" id="filterModalLabel" style="font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px;">
                        <i class="bi bi-sliders" style="color: #8b5cf6;"></i> Filter Orders
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(order_filter_form) }}
                <div class="modal-body" style="padding: 24px;">
                    <div class="mb-3">
                        {{ form_row(order_filter_form.packageName) }}
                    </div>
                    {% if order_filter_form.business is defined %}
                        <div class="mb-3">
                            {{ form_row(order_filter_form.business) }}
                        </div>
                    {% endif %}
                    {% if order_filter_form.consumer is defined %}
                        <div class="mb-3">
                            {{ form_row(order_filter_form.consumer) }}
                        </div>
                    {% endif %}
                </div>
                <div class="modal-footer" style="border-top: 1px solid var(--border); padding: 16px 24px; display: flex; gap: 10px;">
                    <a href="{{ path('app_order') }}" class="eco-btn eco-btn-cancel" style="margin: 0; flex: 1; text-align: center; display: inline-flex; align-items: center; justify-content: center;">
                        Reset Filters
                    </a>
                    {{ form_widget(order_filter_form.submit, {
                        attr: { class: 'eco-btn eco-btn-primary', style: 'margin: 0; flex: 1; background: #8b5cf6; border: none; cursor: pointer;' },
                        label: 'Apply Filters'
                    }) }}
                </div>
                {{ form_end(order_filter_form) }}
            </div>
        </div>
    </div>

    {% if orders|length > 0 %}
        <div class="eco-orders-grid">
            {% for order in orders %}
                <div class="eco-order-card">
                    <div class="eco-order-header">
                        <div class="eco-order-id">Order #{{ order.id }}</div>
                        <div class="eco-order-date">{{ order.createdAt|date('d M Y, H:i') }}</div>
                    </div>

                    <div class="eco-order-package">
                        <div class="eco-order-label">Package</div>
                        <h3 class="eco-order-package-name">{{ order.package.name }}</h3>
                        <p class="eco-order-package-desc">{{ order.package.description }}</p>
                        <div class="eco-order-price">{{ order.package.price }} lei</div>
                    </div>

                    <div class="eco-order-consumer">
                        <div class="eco-order-label">From</div>
                        <p>
                            <strong>{{ order.consumer.firstName }} {{ order.consumer.lastName }}</strong><br>
                            <span style="color: var(--text-muted); font-size: 13px;">{{ order.consumer.phoneNumber }}</span>
                        </p>
                    </div>

                    <div class="eco-order-business">
                        <div class="eco-order-label">Seller</div>
                        <p><strong>{{ order.package.business.name }}</strong></p>
                    </div>

                    <div class="eco-order-actions" style="display: flex; gap: 8px; width: 100%;">
                        <a href="{{ path('app_order_view', {id: order.id}) }}" class="eco-btn eco-btn-primary" style="flex: 1; text-align: center; justify-content: center;">View Details</a>
                        {% if (app.user and app.user.consumer and order.consumer and app.user.consumer.id == order.consumer.id) or (app.user and app.user.business and order.package and order.package.business and app.user.business.id == order.package.business.id) %}
                            <a href="{{ path('app_order_delete', {id: order.id}) }}" class="eco-btn eco-btn-danger" style="flex: 1; text-align: center; justify-content: center;" onclick="return confirm('Cancel this order?')">Cancel Order</a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="eco-empty" style="background: var(--surface); border-radius: var(--radius-lg); border: 1px solid var(--border);">
            📋 No orders yet.
            {% if is_granted('ROLE_CONSUMER') %}
                <a href="{{ path('app_order_new') }}" style="color: var(--primary); font-weight: 600;">Create one</a>
            {% endif %}
        </div>
    {% endif %}
{% endblock %}
