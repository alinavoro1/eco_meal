{% extends 'base.html.twig' %}

{% block title %}{{ category.name }} – Eco Meal{% endblock %}

{% block body %}
    <div class="eco-page-header">
        <h1>{{ category.name }}</h1>
        <a href="{{ path('app_category') }}" class="eco-btn eco-btn-ghost">← Back</a>
    </div>

    <div class="eco-detail-card">
        <div class="eco-detail-row">
            <span class="eco-detail-label">ID</span>
            <span class="eco-detail-value">{{ category.id }}</span>
        </div>
        <div class="eco-detail-row">
            <span class="eco-detail-label">Name</span>
            <span class="eco-detail-value">{{ category.name }}</span>
        </div>

        <div class="eco-detail-actions">
            <a href="{{ path('app_category_edit', {id: category.id}) }}" class="eco-btn eco-btn-primary">Edit</a>
            <a href="{{ path('app_category_delete', {id: category.id}) }}" class="eco-btn eco-btn-danger"
               onclick="return confirm('Delete this category?')">Delete</a>
        </div>
    </div>
{% endblock %}
